REDIS_URL=redis://127.0.0.1:6379/0
QUEUE_NAME=queue:ab1
RESULT_TTL_SECONDS=1800
STORAGE_ROOT=/opt/nucleomic/runtime/tmp
ALLOWED_ORIGINS=https://nucleomic.com,https://www.nucleomic.com

# Optional binary overrides
# Recommended when third-party binaries are installed outside the repository.
# MUSCLE_BIN=/usr/local/bin/muscle
# CLUSTALW_BIN=/usr/local/bin/clustalw
# IQTREE_BIN=/usr/local/bin/iqtree3

# Optional SMTP settings for backend contact endpoint (/api/contact)
# Not required if you keep using the Google Apps Script contact form.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=username
# SMTP_PASS=app-password-or-smtp-password
# SMTP_FROM=no-reply@example.com
# SMTP_TO=contact@nucleomic.com

JOB_TIMEOUT_SECONDS=900
MSA_COMMAND_TIMEOUT_SECONDS=180
TREE_COMMAND_TIMEOUT_SECONDS=900
STALE_RUNNING_SECONDS=1020
