[Unit]
Description=Nucleomic FastAPI App
After=network.target redis-server.service
Wants=redis-server.service

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/nucleomic
EnvironmentFile=/opt/nucleomic/.env
ExecStart=/opt/nucleomic/.venv/bin/python -m uvicorn app.main:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target