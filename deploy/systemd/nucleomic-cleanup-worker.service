[Unit]
Description=Nucleomic Cleanup Worker
After=network.target redis-server.service nucleomic-app.service
Wants=redis-server.service

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/nucleomic
EnvironmentFile=/opt/nucleomic/.env
ExecStart=/opt/nucleomic/.venv/bin/python -m app.workers.cleanup_worker
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target