[Unit]
Description=Nucleomic MSA/Tree Worker
After=network.target redis-server.service nucleomic-app.service
Wants=redis-server.service

[Service]
Type=simple
User=deploy
Group=deploy
WorkingDirectory=/opt/nucleomic
EnvironmentFile=/opt/nucleomic/.env
ExecStart=/opt/nucleomic/.venv/bin/python -m app.workers.msa_tree_worker
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target